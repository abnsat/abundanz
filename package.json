{
  "name": "abundanz",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @abundanz/web dev",
    "dev:mobile": "pnpm --filter @abundanz/mobile start",
    "build:web": "pnpm --filter @abundanz/web build",
    "db:push": "pnpm --filter @abundanz/shared db:push",
    "db:generate": "pnpm --filter @abundanz/shared db:generate",
    "db:migrate": "pnpm --filter @abundanz/shared db:migrate"
  },
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "pnpm": {
    "patchedDependencies": {
      "expo-router@4.0.22": "patches/expo-router@4.0.22.patch",
      "@expo/metro-runtime@4.0.1": "patches/@expo__metro-runtime@4.0.1.patch"
    }
  }
}
